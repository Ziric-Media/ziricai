# ZiricAI environment configuration
# Copy to .env and fill in values before running `npm run dev` or `npm start`

PORT=3000
NODE_ENV=development

# Multi-site URLs (local dev defaults; set production subdomains on deploy)
MARKETING_BASE_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000/app
ADMIN_BASE_URL=http://localhost:3000/admin
API_BASE_URL=
# Production API host (Railway). Used by prepare-sites when API_BASE_URL is unset.
# PRODUCTION_API_URL=https://ziricai-production.up.railway.app

# Meta WhatsApp Cloud API (required for webhook + outbound)
VERIFY_TOKEN=your_meta_webhook_verify_token
PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_TOKEN=your_meta_system_user_or_whatsapp_access_token

# OpenAI (required for AI replies + Sarah)
OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-4o-mini

# Storage & queue
# memory = in-process (no Firestore billing); firestore = persist to Firestore; auto = try firestore, fallback memory
STORAGE_BACKEND=memory
QUEUE_CONCURRENCY=1

# Default tenant for CRM auto-create and unscoped webhook messages
# DEFAULT_COMPANY_ID=demo-central-motors

# Multi-tenant API scope enforcement
# lax  = companyId param/header only (default; suitable for local dev)
# strict = Firebase auth token required; profile companyId must match route companyId
# REQUIRED in production — see docs/deployment/SPRINT5_SECURITY.md
TENANT_SCOPE_ENFORCEMENT=lax

# Platform ops / provisioning (server-side). Send as X-Platform-Api-Key header.
# PLATFORM_API_KEY=your_long_random_secret

# Seed demo tenant data on startup (memory backend only)
# DEMO_SEED=true

# Analytics aggregate batching (events → Firestore rollups)
# ANALYTICS_BATCH_SIZE=25
# ANALYTICS_FLUSH_MS=30000

# Firebase (client SDK — used by portal/admin HTML pages)
# FIREBASE_API_KEY=
# FIREBASE_AUTH_DOMAIN=
# FIREBASE_PROJECT_ID=ziricai

# Netlify static sites (build-time — set in Netlify dashboard per site)
# USE_CDN_FIREBASE=true
# NETLIFY=true

# Integration Hub rate limits (optional)
# INTEGRATION_RATE_LIMIT_PER_MIN=60

# Production Meta webhook callback URL (configure in Meta Developer Console):
#   https://ziricai-production.up.railway.app/webhook
#   (or https://api.ziricai.com/webhook after custom domain)
# Multi-tenant channel webhooks:
#   https://ziricai-production.up.railway.app/webhooks/whatsapp/<companyId>

# Production subdomain mapping (see docs/deployment/NETLIFY.md and RAILWAY.md):
#   marketing.ziricai.com → marketing/ (Netlify)
#   app.ziricai.com       → app/ (Netlify)
#   admin.ziricai.com     → admin/ (Netlify)
#   API                   → Railway (ziricai-production.up.railway.app or api.ziricai.com CNAME)
